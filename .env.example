# Database (Neon)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/comfyui_saas?sslmode=require

# Auth
AUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=comfyui-images
R2_PUBLIC_URL=https://images.yourdomain.com

# ComfyUI
COMFYUI_API_URL=http://localhost:8188
# When using Cloudflare Tunnel:
# COMFYUI_API_URL=https://comfyui-api.yourdomain.com
